local function enforceHUD(mainFrame)
    if mainFrame.Position.X.Scale < 0 or mainFrame.Position.Y.Scale < 0 or mainFrame.Position.Y.Offset < -500 then
        mainFrame.Position = UDim2.new(0, 0, 0.5, 0)
    end
end

local leftCenter = pg:WaitForChild("LeftCenter", 3)
if leftCenter then
    leftCenter:GetPropertyChangedSignal("Enabled"):Connect(function() leftCenter.Enabled = true end)
    local main = leftCenter:FindFirstChild("LeftCenter")
    if main then
        main:GetPropertyChangedSignal("Position"):Connect(function() enforceHUD(main) end)
        enforceHUD(main)
    end
end

local topbar = pg:WaitForChild("TopbarStandard", 3)
if topbar then
    topbar:GetPropertyChangedSignal("Enabled"):Connect(function() topbar.Enabled = true end)
end

pg.ChildAdded:Connect(function(child)
    if child.Name == "TradeLiveTrade" or child.Name == "TradePlayerList" then
        if child.Enabled then child.Parent = game:GetService("Lighting") end
        child:GetPropertyChangedSignal("Enabled"):Connect(function()
            if child.Enabled then child.Parent = game:GetService("Lighting") end
